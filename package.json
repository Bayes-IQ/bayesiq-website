{
  "name": "bayesiq-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "playwright test",
    "test:unit": "vitest run",
    "test:install": "playwright install chromium",
    "generate:types": "bash scripts/generate-types.sh",
    "validate:schemas": "node scripts/validate-schemas.mjs",
    "visual-qa": "VQA_CONFIG=visual-qa.config.json bash ~/BayesIQCode/bayesiq-workspace/visual-qa/run-visual-qa.sh",
    "visual-qa:baseline": "VQA_CONFIG=visual-qa.config.json bash ~/BayesIQCode/bayesiq-workspace/visual-qa/baseline.sh",
    "a11y-check": "npx playwright test e2e/a11y-check.spec.ts --project=chromium --reporter=list",
    "pixel-diff": "VQA_CONFIG=visual-qa.config.json npx tsx ~/BayesIQCode/bayesiq-workspace/visual-qa/pixel-diff.ts",
    "design-debt": "VQA_CONFIG=visual-qa.config.json npx tsx ~/BayesIQCode/bayesiq-workspace/visual-qa/design-debt.ts"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "next": "^15.1.0",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "jsdom": "^29.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
