{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "golden-flows/contract-c/reviewer_attribution",
  "title": "Reviewer Attribution",
  "description": "Reviewer identity records: name, role, organization.",
  "type": "object",
  "required": ["schema_version", "payload_type", "reviewers"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "payload_type": {
      "type": "string",
      "const": "reviewer_attribution"
    },
    "reviewers": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ReviewerRecord"
      }
    }
  },
  "definitions": {
    "ReviewerRecord": {
      "type": "object",
      "required": ["reviewer_id", "name", "role"],
      "additionalProperties": false,
      "properties": {
        "reviewer_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "organization": {
          "type": "string"
        }
      }
    }
  }
}
