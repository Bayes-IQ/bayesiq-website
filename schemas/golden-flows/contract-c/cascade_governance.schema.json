{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "golden-flows/contract-c/cascade_governance",
  "title": "Cascade Governance Overlay",
  "description": "Per-question governance overlay for cascade viewer: approval status, reviewer, linked object IDs. Aligned with platform contract_c.cascade_governance_v1 (PR #329).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "payload_type", "generated_at", "items"],
  "properties": {
    "schema_version": { "const": 1 },
    "payload_type": { "const": "contract_c.cascade_governance" },
    "generated_at": { "type": "string", "format": "date-time" },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/CascadeGovernanceItem" }
    }
  },
  "$defs": {
    "CascadeGovernanceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question_id", "approval_status", "record_origin",
        "reviewer", "finding_ids", "feedback_ids", "event_ids",
        "ts_requested", "ts_resolved"
      ],
      "properties": {
        "question_id": { "type": "string" },
        "approval_status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected", "deferred"]
        },
        "record_origin": {
          "type": "string",
          "enum": ["demo_seeded", "demo_approved", "live"]
        },
        "reviewer": { "$ref": "#/$defs/Reviewer" },
        "review_note": { "type": ["string", "null"] },
        "finding_ids": { "type": "array", "items": { "type": "string" } },
        "feedback_ids": { "type": "array", "items": { "type": "string" } },
        "event_ids": { "type": "array", "items": { "type": "string" } },
        "ts_requested": { "type": "string" },
        "ts_resolved": { "type": "string" }
      }
    },
    "Reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewer_id"],
      "properties": {
        "reviewer_id": { "type": "string" },
        "display_name": { "type": ["string", "null"] },
        "role": { "type": ["string", "null"] }
      }
    }
  }
}
