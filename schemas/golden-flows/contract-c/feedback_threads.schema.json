{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "golden-flows/contract-c/feedback_threads",
  "title": "Feedback Threads",
  "description": "Feedback item state with linked approvals. Aligned with platform contract_c.feedback_threads_v1 (PR #317).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "payload_type", "generated_at", "items"],
  "properties": {
    "schema_version": { "const": 1 },
    "payload_type": { "const": "contract_c.feedback_threads" },
    "generated_at": { "type": "string", "format": "date-time" },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/FeedbackItem" }
    }
  },
  "$defs": {
    "FeedbackItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "feedback_id", "summary", "status", "disposition", "timeline",
        "linked_approvals"
      ],
      "properties": {
        "feedback_id": { "type": "string" },
        "summary": { "type": "string" },
        "category": { "type": ["string", "null"] },
        "priority": { "type": ["string", "null"] },
        "status": { "type": "string" },
        "disposition": {
          "type": "string",
          "enum": ["pending", "in_progress", "resolved", "rejected"]
        },
        "resolution_note": { "type": ["string", "null"] },
        "source": { "type": ["string", "null"] },
        "timeline": { "$ref": "#/$defs/Timeline" },
        "linked_approvals": {
          "type": "array",
          "items": { "$ref": "#/$defs/LinkedApproval" }
        }
      }
    },
    "Timeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "updated_at", "resolved_at"],
      "properties": {
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "resolved_at": { "type": "string" }
      }
    },
    "LinkedApproval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_id", "approval_status", "record_origin",
        "reviewer", "ts_requested", "ts_resolved"
      ],
      "properties": {
        "approval_id": { "type": "string" },
        "approval_status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected", "deferred"]
        },
        "record_origin": {
          "type": "string",
          "enum": ["demo_seeded", "demo_approved", "live"]
        },
        "reviewer": { "$ref": "#/$defs/Reviewer" },
        "ts_requested": { "type": "string" },
        "ts_resolved": { "type": "string" },
        "review_note": { "type": ["string", "null"] }
      }
    },
    "Reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewer_id"],
      "properties": {
        "reviewer_id": { "type": "string" },
        "display_name": { "type": ["string", "null"] },
        "role": { "type": ["string", "null"] }
      }
    }
  }
}
