{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "golden-flows/contract-c/approval_status",
  "title": "Approval Metadata",
  "description": "Per-finding/feedback approval status with inline reviewer attribution. Aligned with platform contract_c.approval_metadata_v1 (PR #316).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "payload_type", "generated_at", "items"],
  "properties": {
    "schema_version": { "const": 1 },
    "payload_type": { "const": "contract_c.approval_metadata" },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "UTC ISO 8601 timestamp of export generation"
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/ApprovalItem" }
    }
  },
  "$defs": {
    "ApprovalItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_type", "object_id", "approval_status", "record_origin",
        "source_approval_id", "reviewer", "timestamp"
      ],
      "properties": {
        "object_type": {
          "type": "string",
          "enum": ["finding", "feedback", "approval"],
          "description": "What kind of object this approval covers"
        },
        "object_id": {
          "type": "string",
          "description": "ID of the finding, feedback, or approval being approved. References Contract B cascade_data for findings."
        },
        "approval_status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected", "deferred"]
        },
        "record_origin": {
          "type": "string",
          "enum": ["demo_seeded", "demo_approved", "live"],
          "description": "Whether this record was seeded for demo, approved during demo, or from live production"
        },
        "source_approval_id": {
          "type": "string",
          "description": "Platform-internal approval record ID for traceability"
        },
        "reviewer": { "$ref": "#/$defs/Reviewer" },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "UTC ISO 8601 timestamp of the approval action"
        },
        "review_note": {
          "type": ["string", "null"],
          "maxLength": 500,
          "description": "Optional reviewer note, max 500 chars"
        }
      }
    },
    "Reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewer_id"],
      "properties": {
        "reviewer_id": { "type": "string" },
        "display_name": {
          "type": ["string", "null"],
          "description": "Human-readable reviewer name"
        },
        "role": {
          "type": ["string", "null"],
          "description": "Reviewer role (e.g., admin, analyst)"
        }
      }
    }
  }
}
