{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "golden-flows/contract-b/executive_questions",
  "title": "Executive Questions",
  "description": "Per-vertical executive questions with answer summaries for question buttons and cascade entry points.",
  "type": "object",
  "required": ["schema_version", "payload_type", "vertical", "questions"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "payload_type": {
      "type": "string",
      "const": "executive_questions"
    },
    "vertical": {
      "type": "string",
      "enum": ["hospital", "real_estate", "saas", "retail", "fintech"]
    },
    "questions": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ExecutiveQuestion"
      },
      "minItems": 1,
      "maxItems": 10
    }
  },
  "definitions": {
    "ExecutiveQuestion": {
      "type": "object",
      "required": ["question_id", "priority", "question_text", "answer_summary", "severity"],
      "additionalProperties": false,
      "properties": {
        "question_id": {
          "type": "string",
          "description": "Stable ID: {vertical}_{snapshot}_{Q_NNN}"
        },
        "priority": {
          "type": "string",
          "enum": ["flagship", "secondary"]
        },
        "question_text": {
          "type": "string",
          "minLength": 1
        },
        "answer_summary": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        }
      }
    }
  }
}
